# =============================================================
# CongregaFiel — Variáveis de Ambiente
# Copie este arquivo para .env em cada pasta de API e preencha os valores
# =============================================================

# Supabase (obtenha em: https://supabase.com/dashboard → Settings → API)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SECRET_KEY=sua-service-role-key-aqui

# JWT — Secret do Supabase (Settings → API → JWT Secret)
# Necessário para o API Gateway validar tokens de autenticação
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui

# API Gateway — Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=30000

# API Gateway — URLs dos Microserviços
FASTAPI_URL=http://localhost:8000
AUTH_SERVICE_URL=http://localhost:4001
NOTIFICATION_SERVICE_URL=http://localhost:4009

# Firebase — Cloud Messaging (obtenha em: https://console.firebase.google.com)
FIREBASE_API_KEY=sua-api-key-aqui
FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
FIREBASE_PROJECT_ID=seu-projeto-id
FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
FIREBASE_MESSAGING_SENDER_ID=seu-sender-id
FIREBASE_APP_ID=seu-app-id
FIREBASE_VAPID_KEY=sua-vapid-key-publica

# Firebase Admin SDK (para notification-service)
FIREBASE_SERVICE_ACCOUNT_KEY={"type": "service_account", ...}
